# --- Provider selection ---
# Which follow-data provider the worker uses: twitterapiio | sorsa
# Only the selected provider's API key is required.
TWITTER_PROVIDER=twitterapiio

# --- twitterapi.io (default provider) ---
# Get your key from https://twitterapi.io/ (sent as the X-API-Key header).
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here
TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io
# Followings page size per request (first page only). twitterapi.io's followings
# endpoint has a minimum pageSize of 20 (lower values are clamped up to 20).
# Billing is per returned user: 20–99 users = 3 credits/user, so pageSize=20
# costs 60 credits per influencer poll — the cheapest useful setting.
TWITTERAPI_PAGE_SIZE=20
# Count-gated polling (cost control): before each 60-credit followings fetch,
# read the cheap (18-credit) profile `following` count and skip the fetch when
# it hasn't moved since last cycle. Big credit savings at faster poll intervals.
TWITTERAPI_COUNT_GATE_ENABLED=true
# Force a full followings fetch at least this often (hours) per influencer, even
# when the count is unchanged — catches same-interval follow+unfollow churn (net
# count unchanged) and refreshes the snapshot.
TWITTERAPI_FULL_REBASELINE_HOURS=24

# --- Sorsa API (alternative provider; set TWITTER_PROVIDER=sorsa to use) ---
# Get your key from https://api.sorsa.io/
SORSA_API_KEY=your_sorsa_api_key_here
# Optional override; defaults to https://api.sorsa.io/v3
SORSA_BASE_URL=https://api.sorsa.io/v3

# --- Alert channels ---
# Per-channel toggles. A disabled channel is never called, so its credentials
# below can stay as placeholders. Defaults: Telegram off, Discord on.
ALERT_TELEGRAM_ENABLED=false
ALERT_DISCORD_ENABLED=true

# --- Telegram ---
# Create a bot via @BotFather to get the token. (Only needed if ALERT_TELEGRAM_ENABLED=true.)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat / channel id the bot should post to (e.g. -1001234567890 or a numeric user id).
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Discord ---
# Channel settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# (Only needed if ALERT_DISCORD_ENABLED=true.)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# --- Worker ---
# Scheduler tick (minutes): how often the worker wakes. On each tick only
# accounts whose per-tier interval has elapsed are polled (super_vip=2m,
# vip=5m, normal=15m, slow=60m, disabled=never — set per account via `tier` in
# src/config.ts). Set
# this to (or below) the smallest tier interval you use, so the tightest tier is
# honored to the minute; a larger tick rounds detection up to the tick. With
# vip=2m the recommended value is 1.
POLL_INTERVAL_MINUTES=1

# Set to true to run a single cycle and exit (useful for testing / cron / PM2 one-shot).
RUN_ONCE=false

# Path to the SQLite database file.
DB_PATH=./data/tracker.db
