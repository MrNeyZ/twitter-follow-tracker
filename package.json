{
  "name": "twitter-follow-tracker",
  "version": "0.1.0",
  "description": "Minimal backend worker that monitors Crypto Twitter influencers' new follows via Sorsa API and alerts to Telegram + Discord.",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "once": "RUN_ONCE=true ts-node src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:scoring": "ts-node scripts/scoring-fixture-test.ts",
    "test:polling": "ts-node scripts/polling-test.ts",
    "test:smoke": "npm run build && node smoke-test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "playwright": "^1.60.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
